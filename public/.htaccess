# Serve the SPA's index.html for any route that isn't a real file/directory,
# so direct links and page refreshes on routes like /services or /about work
# (React Router handles the path client-side after that). Without this,
# Apache 404s on anything but the exact homepage URL.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
